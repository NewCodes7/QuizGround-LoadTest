{
  "dependencies": {
    "artillery": "^2.0.30",
    "concurrently": "^9.1.0",
    "socket.io-client": "^4.8.1"
  },
  "name": "artillery-quiz-ground",
  "version": "1.0.0",
  "main": "create-room-processor.js",
  "scripts": {
    "init:dev": "TARGET=http://localhost:3000/game node ./create-room.js",
    "init:prod": "TARGET=http://34.158.197.135/game DURATION=10000 node ./create-room.js",
    "start:dev": "TARGET=http://localhost:3000/game artillery run ./game-scenario.yml",
    "start:prod": "TARGET=http://34.158.197.135/game GAME_ID=672808 artillery run ./game-scenario.yml",
    "init:dev:10k": "TARGET=http://localhost:3000/game node ./create-room-10k.js",
    "init:prod:10k": "TARGET=http://34.158.197.135/game node ./create-room-10k.js",
    "start:dev:10k": "TARGET=http://localhost:3000/game GAME_ID=$GAME_ID artillery run ./game-scenario-10k.yml",
    "start:prod:10k": "TARGET=http://34.158.197.135/game GAME_ID=$GAME_ID artillery run ./game-scenario-10k.yml",
    "fargate:10k": "bash ./fargate-10k.sh",
    "fargate:10k:heavy": "CPU=4 MEMORY=8 SPOT=0 bash ./fargate-10k.sh",
    "init:dev:10": "TARGET=http://localhost:3000/game node ./create-room-10.js",
    "init:prod:10": "TARGET=http://34.158.197.135/game node ./create-room-10.js",
    "start:dev:10": "TARGET=http://localhost:3000/game GAME_ID=$GAME_ID artillery run ./game-scenario-10.yml",
    "start:prod:10": "TARGET=http://34.158.197.135/game GAME_ID=$GAME_ID artillery run ./game-scenario-10.yml",
    "fargate:10": "bash ./fargate-10.sh",
    "init:dev:200": "TARGET=http://localhost:3000/game node ./create-room.js",
    "init:prod:200": "TARGET=http://34.158.197.135/game node ./create-room.js",
    "start:dev:200": "TARGET=http://localhost:3000/game GAME_ID=$GAME_ID artillery run ./game-scenario.yml",
    "start:prod:200": "TARGET=http://34.158.197.135/game GAME_ID=$GAME_ID artillery run ./game-scenario.yml",
    "fargate:200": "bash ./fargate-200.sh"
  },
